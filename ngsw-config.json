{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/mobile/index.html",
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/mobile/favicon.ico",
          "/mobile/index.html",
          "/mobile/manifest.webmanifest",
          "/mobile/*.css",
          "/mobile/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/mobile/assets/**",
          "/mobile/svg/**",
          "/mobile/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-no-cache",
      "urls": [
        "/api/**"
      ],
      "cacheConfig": {
        "maxSize": 1,
        "maxAge": "0s",
        "timeout": "30s",
        "strategy": "freshness"
      }
    }
  ]
}
